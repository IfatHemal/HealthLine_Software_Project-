<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DoctorHomeFragment"
    android:background="#D6EED6"
    android:fillViewport="true"
    >





        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">


            <HorizontalScrollView
                android:id="@+id/scrollview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="240dp"
                        android:layout_height="160dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_doctor_card_pink"
                        android:padding="20dp"
                        android:layout_marginEnd="14dp">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="24sp"
                            android:layout_marginBottom="12dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳18k"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Income"
                            android:textColor="#E0C8FF"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 completed"
                            android:textColor="#D0B0FF"
                            android:textSize="13sp" />

                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="240dp"
                        android:layout_height="160dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_doctor_card_blue"
                        android:padding="20dp"
                        android:layout_marginEnd="14dp">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱"
                            android:textSize="26sp"
                            android:layout_marginBottom="12dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15m"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg. Time/Patient"
                            android:textColor="#FFD0B0"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="within target"
                            android:textColor="#FFBB99"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="240dp"
                        android:layout_height="160dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_doctor_card_pink"
                        android:padding="20dp"
                        android:layout_marginEnd="14dp">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="24sp"
                            android:layout_marginBottom="12dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳18k"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Income"
                            android:textColor="#E0C8FF"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 completed"
                            android:textColor="#D0B0FF"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="৳18k"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="240dp"
                        android:layout_height="160dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_doctor_card_blue"
                        android:padding="20dp"
                        android:layout_marginEnd="14dp">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="24sp"
                            android:layout_marginBottom="12dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Income"
                            android:textColor="#E0C8FF"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 completed"
                            android:textColor="#D0B0FF"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="14dp">


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginEnd="7dp">

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_blue"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Appointments"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/updateserial"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginStart="7dp">

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_green"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Queue"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="14dp">


                <LinearLayout
                    android:id="@+id/manageDoctorSchedule"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginEnd="7dp">

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_purple"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗓"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Schedule"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/manageprofile"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginStart="7dp"

                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    >

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_orange"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Profile"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="14dp">


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginEnd="7dp">

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_yellow"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reports &amp; Analytics"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_white"
                    android:layout_marginStart="7dp">

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_pink"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Feedback"
                        android:textSize="13sp"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>


</ScrollView>