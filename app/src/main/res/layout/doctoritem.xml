<?xml version="1.0" encoding="utf-8"?>


    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:background="@drawable/bg_icon_box_green"
        android:layout_marginBottom="10dp"
        android:elevation="2dp">


        <ImageView

            android:id="@+id/imgDoctor"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:src="@drawable/default_profile_picture"
            android:scaleType="centerCrop"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                >
                <TextView
                    android:id="@+id/tvName"
                    android:text="Dr. Name"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:layout_weight="2"/>





            </LinearLayout>




            <TextView
                android:id="@+id/tvSpeciality"
                android:text="Cardiologist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />

            <TextView
                android:id="@+id/tvHospital"
                android:text="Hospital Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />

            <TextView
                android:id="@+id/tvSchedule"
                android:text="Sat, Mon (10AM-2PM)"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />

            <TextView
                android:id="@+id/tvExperience"
                android:text="5 Years Experience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />

            <TextView
                android:id="@+id/tvFee"
                android:text="Fee: 500৳"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />


            <TextView
                android:id="@+id/tvRating"
                android:text="⭐ 4.5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                >


            <Button
                android:id="@+id/review"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Review"
                android:layout_gravity="left"
                android:layout_marginRight="7dp"
                android:layout_weight="1"
                android:backgroundTint="#0080B2"

                />


            <Button
                android:id="@+id/book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book"
                android:layout_gravity="right"
                android:layout_marginRight="7dp"
                android:layout_weight="1"
                android:backgroundTint="#0028F6"
                android:textColor="#ffffff"
                />


            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

